/com,--- Number of total elements = %_numelem%
*get,_wallbsol,active,,time,wall
/solu
antype,2                   ! modal analysis
_thickRatio=  1     ! Ratio of thick parts in the model
modopt,lanb,6
outres,erase
outres,all,none
outres,nsol,all
outres,etmp,all
outres,strs,all
outres,epel,all
outres,eppl,all
outres,rsol,all
nsel,s,d,U
nsel,a,d,ROT
esln
cm,_ConstrainedNodes,elem  ! -- reduced set with only constrained nodes
nsel,all
esel,all
